{
  "name": "@ronaldmiranda/api-sdk",
  "version": "1.1.2",
  "description": "SDK oficial para integração com a RNLD API — whitelist e query de jogadores",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "rnld",
    "fivem",
    "whitelist",
    "discord",
    "bot",
    "sdk"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rnld-store/rnld-api-sdk.git"
  },
  "homepage": "https://github.com/rnld-store/rnld-api-sdk#readme",
  "bugs": {
    "url": "https://github.com/rnld-store/rnld-api-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
